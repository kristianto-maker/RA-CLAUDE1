export default function App() {
  const [page, setPage] = useState("landing");
  const [user, setUser] = useState(null);
  return (
    <div style={{fontFamily:"'Outfit','Segoe UI',system-ui,sans-serif"}}>
      <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
      <style>{`@keyframes slideIn{from{transform:translateX(100px);opacity:0}to{transform:translateX(0);opacity:1}}@keyframes fadeUp{from{transform:translateY(12px);opacity:0}to{transform:translateY(0);opacity:1}}*{scrollbar-width:thin;scrollbar-color:#cbd5e1 transparent}::-webkit-scrollbar{width:6px}::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:8px}`}</style>
      {page==="landing"&&<LandingPage onNavigate={setPage}/>}
      {(page==="login"||page==="register")&&<AuthPage mode={page} onNavigate={setPage} onLogin={u=>{setUser(u);setPage("dashboard");}}/>}
      {page==="dashboard"&&user&&<Dashboard user={user} onLogout={()=>{setUser(null);setPage("landing");}}/>}
    </div>
  );
}
