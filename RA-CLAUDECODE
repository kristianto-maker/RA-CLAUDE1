        <nav className="flex-1 py-4 px-2 overflow-y-auto">{menus.filter(m=>m.r.includes(user.role)).map(m=>{if(m.id.startsWith("d"))return<hr key={m.id} className="my-3 border-slate-100"/>;return<button key={m.id} onClick={()=>setAM(m.id)} className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl mb-0.5 text-sm font-medium transition-all ${aM===m.id?"bg-teal-50 text-teal-700 shadow-sm":"text-slate-600 hover:bg-slate-50"}`}><m.icon size={18} className="shrink-0"/>{sO&&<span className="truncate">{m.label}</span>}</button>;})}</nav>
        <div className="p-3 border-t border-slate-100"><div className={`flex items-center gap-3 ${sO?"":"justify-center"}`}><Avatar name={user.name} size={34}/>{sO&&<div className="min-w-0 flex-1"><div className="text-xs font-bold text-slate-700 truncate">{user.name}</div><Badge variant={isA?"danger":"primary"}>{isA?"Admin":"Peneliti"}</Badge></div>}</div></div>
      </aside>

      <main className={`flex-1 transition-all duration-300 ${sO?"ml-64":"ml-16"}`}>
