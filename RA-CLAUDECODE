function AuthPage({ mode, onNavigate, onLogin }) {
  const [isL, setIsL] = useState(mode==="login");
  const [showPw, setShowPw] = useState(false);
  const [form, setForm] = useState({name:"",email:"",password:"",role:"peneliti"});
  const [loading, setLoading] = useState(false);
  const submit = ()=>{setLoading(true);setTimeout(()=>{setLoading(false);if(isL){const role=form.email.includes("admin")?"admin":"peneliti";onLogin({name:role==="admin"?"Admin Jurusan":"Dr. Hj. Siti Nurhasanah, M.Kes.",email:form.email,role});}else setIsL(true);},1200);};
  return (
    <div className="min-h-screen flex" style={{background:"linear-gradient(135deg,#0f766e 0%,#0e7490 50%,#1e40af 100%)"}}>
      <div className="hidden lg:flex lg:w-1/2 flex-col justify-center items-center p-12 relative overflow-hidden">
        <div className="absolute inset-0 opacity-10">{[...Array(6)].map((_,i)=><div key={i} className="absolute rounded-full border border-white/30" style={{width:100+i*80,height:100+i*80,top:"50%",left:"50%",transform:"translate(-50%,-50%)"}}/>)}</div>
        <div className="relative z-10 text-center"><div className="w-20 h-20 rounded-2xl bg-white/20 backdrop-blur-lg flex items-center justify-center mx-auto mb-6 shadow-2xl"><Microscope size={40} className="text-white"/></div><h2 className="text-3xl font-extrabold text-white mb-3" style={{fontFamily:"'Outfit',sans-serif"}}>SciMap<span className="text-teal-200">Polsub</span></h2><p className="text-teal-100 text-sm max-w-sm leading-relaxed">Sistem Pemetaan Luaran Ilmiah Berbasis Data Terbuka</p>
          <div className="flex flex-wrap gap-2 mt-8 justify-center">{Object.values(API_SOURCES).map(s=><span key={s.id} className="px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs border border-white/20">{s.icon} {s.name}</span>)}</div>
        </div>
      </div>
      <div className="flex-1 flex items-center justify-center p-6 sm:p-8"><div className="w-full max-w-md"><div className="bg-white rounded-3xl shadow-2xl p-6 sm:p-8">
        <button onClick={()=>onNavigate("landing")} className="flex items-center gap-1.5 text-xs text-slate-500 hover:text-teal-600 mb-6"><ChevronRight size={14} className="rotate-180"/>Kembali ke Beranda</button>
        <div className="flex bg-slate-100 rounded-xl p-1 mb-6"><button onClick={()=>setIsL(true)} className={`flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all ${isL?"bg-white text-teal-700 shadow-md":"text-slate-500"}`}>Masuk</button><button onClick={()=>setIsL(false)} className={`flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all ${!isL?"bg-white text-teal-700 shadow-md":"text-slate-500"}`}>Daftar</button></div>
        <h2 className="text-xl font-extrabold text-slate-800 mb-1" style={{fontFamily:"'Outfit',sans-serif"}}>{isL?"Selamat Datang Kembali":"Buat Akun Baru"}</h2>
        <p className="text-sm text-slate-500 mb-6">{isL?"Masuk ke dasbor pengelolaan publikasi.":"Daftar untuk mengelola luaran ilmiah."}</p>
        <div className="space-y-4">
          {!isL&&<div><label className="block text-xs font-semibold text-slate-700 mb-1.5">Nama Lengkap</label><div className="relative"><User size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"/><input type="text" placeholder="Dr. Nama, M.Kes." value={form.name} onChange={e=>setForm({...form,name:e.target.value})} className="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 text-sm outline-none"/></div></div>}
          <div><label className="block text-xs font-semibold text-slate-700 mb-1.5">Email Institusi</label><div className="relative"><Mail size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"/><input type="email" placeholder="nama@polsub.ac.id" value={form.email} onChange={e=>setForm({...form,email:e.target.value})} className="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 text-sm outline-none"/></div></div>
          <div><label className="block text-xs font-semibold text-slate-700 mb-1.5">Kata Sandi</label><div className="relative"><Lock size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"/><input type={showPw?"text":"password"} placeholder="••••••••" value={form.password} onChange={e=>setForm({...form,password:e.target.value})} className="w-full pl-10 pr-10 py-2.5 rounded-xl border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 text-sm outline-none"/><button onClick={()=>setShowPw(!showPw)} className="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">{showPw?<EyeOff size={16}/>:<Eye size={16}/>}</button></div></div>
          {!isL&&<div><label className="block text-xs font-semibold text-slate-700 mb-1.5">Role</label><div className="flex gap-2">{[{k:"peneliti",l:"Peneliti/Dosen",i:GraduationCap},{k:"admin",l:"Admin Jurusan",i:Shield}].map(r=><button key={r.k} onClick={()=>setForm({...form,role:r.k})} className={`flex-1 flex items-center gap-2 p-3 rounded-xl border text-xs font-semibold ${form.role===r.k?"border-teal-400 bg-teal-50 text-teal-700 shadow-md":"border-slate-200 text-slate-500"}`}><r.i size={16}/>{r.l}</button>)}</div></div>}
          <button onClick={submit} disabled={loading} className="w-full py-3 bg-gradient-to-r from-teal-600 to-cyan-600 text-white font-semibold rounded-xl shadow-xl shadow-teal-200 flex items-center justify-center gap-2 text-sm disabled:opacity-60">{loading?<RefreshCw size={18} className="animate-spin"/>:isL?<><LogIn size={18}/>Masuk ke Dasbor</>:<><UserPlus size={18}/>Daftar Sekarang</>}</button>
          {isL&&<div className="bg-amber-50 border border-amber-200 rounded-xl p-3 mt-3"><p className="text-xs text-amber-700 font-medium mb-1">🔑 Demo Login:</p><p className="text-xs text-amber-600"><strong>Admin:</strong> admin@polsub.ac.id</p><p className="text-xs text-amber-600"><strong>Peneliti:</strong> siti@polsub.ac.id</p><p className="text-xs text-amber-600">Password: apapun (demo mode)</p></div>}
        </div>
      </div></div></div>
    </div>
  );
}

