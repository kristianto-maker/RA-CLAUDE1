function useCounter(end, dur = 2000) {
  const [c, setC] = useState(0);
  useEffect(() => { let s=0; const inc=end/(dur/16); const t=setInterval(()=>{s+=inc;if(s>=end){setC(end);clearInterval(t);}else setC(Math.floor(s));},16); return()=>clearInterval(t); }, [end, dur]);
  return c;
}
function Avatar({ name, size = 40 }) {
  const cols = ["#0d9488","#0284c7","#7c3aed","#db2777","#ea580c","#16a34a"];
  const ini = name.split(" ").filter(w=>w.length>2).slice(0,2).map(w=>w[0]).join("");
  return <div style={{width:size,height:size,backgroundColor:cols[name.length%cols.length],fontSize:size*.38}} className="rounded-full flex items-center justify-center text-white font-bold shrink-0 shadow-md">{ini}</div>;
}
function Badge({ children, variant = "default" }) {
  const s = { default:"bg-slate-100 text-slate-600", primary:"bg-teal-50 text-teal-700 border border-teal-200", success:"bg-emerald-50 text-emerald-700 border border-emerald-200", warning:"bg-amber-50 text-amber-700 border border-amber-200", danger:"bg-rose-50 text-rose-700 border border-rose-200", info:"bg-sky-50 text-sky-700 border border-sky-200", purple:"bg-violet-50 text-violet-700 border border-violet-200" };
  return <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${s[variant]}`}>{children}</span>;
}
function Toast({ message, type="success", onClose }) {
  useEffect(()=>{const t=setTimeout(onClose,3500);return()=>clearTimeout(t);},[onClose]);
  return <div className={`fixed top-6 right-6 z-[9999] ${type==="success"?"bg-emerald-600":"bg-rose-600"} text-white px-5 py-3 rounded-xl shadow-2xl flex items-center gap-3`} style={{animation:"slideIn .3s ease-out"}}>{type==="success"?<CheckCircle size={18}/>:<AlertCircle size={18}/>}<span className="text-sm font-medium">{message}</span></div>;
}

// ─── COLLAB GRAPH ───
function CollabGraph() {
  const [hov, setHov] = useState(null);
  const nm = useMemo(()=>Object.fromEntries(COLLAB_NODES.map(n=>[n.id,n])),[]);
  return (
    <svg viewBox="0 0 700 480" className="w-full h-auto" style={{maxHeight:420}}>
      <defs><radialGradient id="gl" cx="50%" cy="50%" r="50%"><stop offset="0%" stopColor="#0d9488" stopOpacity=".15"/><stop offset="100%" stopColor="#0d9488" stopOpacity="0"/></radialGradient><filter id="sh"><feDropShadow dx="0" dy="2" stdDeviation="4" floodColor="#0d9488" floodOpacity=".25"/></filter></defs>
      {COLLAB_EDGES.map((e,i)=>{const f=nm[e.from],t=nm[e.to],a=hov===e.from||hov===e.to;return<line key={i} x1={f.x} y1={f.y} x2={t.x} y2={t.y} stroke={a?"#0d9488":"#cbd5e1"} strokeWidth={Math.max(1.5,e.strength*.7)} strokeDasharray={e.strength<3?"6,4":"none"} opacity={a?1:.5} style={{transition:"all .3s"}}/>;
      })}
      {COLLAB_NODES.map(n=>{const a=hov===n.id;return(
        <g key={n.id} onMouseEnter={()=>setHov(n.id)} onMouseLeave={()=>setHov(null)} style={{cursor:"pointer"}}>
          {n.primary&&<circle cx={n.x} cy={n.y} r={n.r+20} fill="url(#gl)"/>}
          <circle cx={n.x} cy={n.y} r={a?n.r+4:n.r} fill={n.primary?"#0d9488":a?"#0284c7":"#f1f5f9"} stroke={n.primary?"#0f766e":a?"#0284c7":"#94a3b8"} strokeWidth={n.primary?3:2} filter={a?"url(#sh)":"none"} style={{transition:"all .3s"}}/>
          {n.label.split("\n").map((l,li)=><text key={li} x={n.x} y={n.y+(li-.5)*13} textAnchor="middle" dominantBaseline="central" fill={n.primary?"white":a?"#0c4a6e":"#475569"} fontSize={n.primary?10:9} fontWeight={n.primary?700:500} style={{pointerEvents:"none"}}>{l}</text>)}
        </g>);})}
    </svg>
  );
}

