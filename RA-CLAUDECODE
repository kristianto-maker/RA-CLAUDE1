    {id:"kelola-user",label:"Kelola Pengguna",icon:Users,r:["admin"]},{id:"d2",label:"",r:["peneliti","admin"]},{id:"settings",label:"Pengaturan",icon:Settings,r:["peneliti","admin"]},
