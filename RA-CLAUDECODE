        </header>
        <div className="p-4 sm:p-6 lg:p-8">
          {aM==="overview"&&<div className="space-y-6">
            <div className="bg-gradient-to-r from-teal-600 via-cyan-600 to-blue-600 rounded-2xl p-6 text-white shadow-xl"><h2 className="text-lg font-bold mb-1" style={{fontFamily:"'Outfit',sans-serif"}}>{isA?"Dashboard Admin — Jurusan Kesehatan":`Selamat datang, ${user.name.split(",")[0]}`}</h2><p className="text-teal-100 text-sm">{isA?"Pantau seluruh luaran ilmiah dan kelola konten website.":"Kelola dan pantau publikasi serta profil akademik Anda."}</p></div>
            <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">{(isA?[{l:"Total Dosen",v:"6",i:Users,c:"text-teal-600 bg-teal-50"},{l:"Total Publikasi",v:"121",i:BookOpen,c:"text-blue-600 bg-blue-50"},{l:"Scopus",v:"16",i:Award,c:"text-amber-600 bg-amber-50"},{l:"Total Sitasi",v:"695",i:TrendingUp,c:"text-emerald-600 bg-emerald-50"}]:[{l:"Publikasi Saya",v:"23",i:BookOpen,c:"text-teal-600 bg-teal-50"},{l:"Total Sitasi",v:"87",i:TrendingUp,c:"text-blue-600 bg-blue-50"},{l:"H-Index",v:"5",i:Award,c:"text-amber-600 bg-amber-50"},{l:"Skor SINTA",v:"312",i:Star,c:"text-emerald-600 bg-emerald-50"}]).map((s,i)=><div key={i} className="bg-white rounded-xl p-4 shadow-md border border-slate-100"><div className={`w-9 h-9 rounded-lg ${s.c} flex items-center justify-center mb-2`}><s.i size={18}/></div><div className="text-2xl font-extrabold text-slate-800">{s.v}</div><div className="text-xs text-slate-500">{s.l}</div></div>)}</div>
            <div className="grid lg:grid-cols-2 gap-6">
              <div className="bg-white rounded-xl p-5 shadow-md border border-slate-100"><h3 className="text-sm font-bold text-slate-700 mb-4 flex items-center gap-2"><BarChart3 size={16} className="text-teal-600"/>Publikasi per Tahun</h3><ResponsiveContainer width="100%" height={220}><BarChart data={YEARLY_STATS}><CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9"/><XAxis dataKey="year" tick={{fontSize:11}} stroke="#94a3b8"/><YAxis tick={{fontSize:11}} stroke="#94a3b8"/><Tooltip contentStyle={{borderRadius:12}}/><Bar dataKey="publikasi" fill="#0d9488" radius={[6,6,0,0]}/></BarChart></ResponsiveContainer></div>
              <div className="bg-white rounded-xl p-5 shadow-md border border-slate-100"><h3 className="text-sm font-bold text-slate-700 mb-4 flex items-center gap-2"><Layers size={16} className="text-teal-600"/>{isA?"Distribusi SINTA":"Sitasi Kumulatif"}</h3>{isA?<ResponsiveContainer width="100%" height={220}><BarChart data={SINTA_B} layout="vertical"><CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9"/><XAxis type="number" tick={{fontSize:11}} stroke="#94a3b8"/><YAxis dataKey="tier" type="category" tick={{fontSize:12,fontWeight:600}} stroke="#94a3b8" width={40}/><Tooltip contentStyle={{borderRadius:12}}/><Bar dataKey="count" radius={[0,6,6,0]}>{SINTA_B.map((e,i)=><Cell key={i} fill={e.color}/>)}</Bar></BarChart></ResponsiveContainer>:<ResponsiveContainer width="100%" height={220}><LineChart data={YEARLY_STATS}><CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9"/><XAxis dataKey="year" tick={{fontSize:11}} stroke="#94a3b8"/><YAxis tick={{fontSize:11}} stroke="#94a3b8"/><Tooltip contentStyle={{borderRadius:12}}/><Line type="monotone" dataKey="sitasi" stroke="#0284c7" strokeWidth={2.5} dot={{r:5,fill:"#0284c7"}}/></LineChart></ResponsiveContainer>}</div>
            </div>
          </div>}

          {aM==="profil"&&<div className="space-y-6"><div className="bg-white rounded-xl p-6 shadow-md border border-slate-100"><div className="flex flex-col sm:flex-row gap-5 items-start"><Avatar name={isA?"Admin":RESEARCHERS[0].name} size={72}/><div className="flex-1"><h2 className="text-lg font-extrabold text-slate-800">{isA?"Administrator":RESEARCHERS[0].name}</h2><p className="text-sm text-slate-500">{isA?"Admin":RESEARCHERS[0].prodi}</p>{!isA&&<div className="flex flex-wrap gap-2 mt-3"><Badge variant="primary">NIDN: {RESEARCHERS[0].nidn}</Badge><Badge variant="success">SINTA: {RESEARCHERS[0].sinta_id}</Badge></div>}</div><button className="px-4 py-2 text-xs font-semibold text-teal-700 bg-teal-50 border border-teal-200 rounded-xl flex items-center gap-2"><Edit3 size={14}/>Edit</button></div></div>{!isA&&<div className="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">{[{l:"Skor SINTA",v:RESEARCHERS[0].sinta_score,i:Star,c:"text-teal-600"},{l:"H-Index",v:RESEARCHERS[0].h_index,i:TrendingUp,c:"text-blue-600"},{l:"Publikasi",v:RESEARCHERS[0].publications,i:BookOpen,c:"text-emerald-600"},{l:"Scopus",v:RESEARCHERS[0].scopus,i:Award,c:"text-amber-600"}].map((m,i)=><div key={i} className="bg-white rounded-xl p-5 shadow-md border border-slate-100 text-center"><m.i size={22} className={`mx-auto mb-2 ${m.c}`}/><div className="text-3xl font-extrabold text-slate-800">{m.v}</div><div className="text-sm font-semibold text-slate-700 mt-1">{m.l}</div></div>)}</div>}</div>}

          {aM==="publikasi"&&<div className="space-y-4"><div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3"><div><h2 className="text-lg font-bold text-slate-800">Daftar Publikasi</h2><p className="text-xs text-slate-500">Data dari 6 sumber terbuka</p></div><div className="flex gap-2"><button className="flex items-center gap-2 px-4 py-2 text-xs font-semibold bg-white border border-slate-200 rounded-xl text-slate-600"><Filter size={14}/>Filter</button><button className="flex items-center gap-2 px-4 py-2 text-xs font-semibold bg-white border border-slate-200 rounded-xl text-slate-600"><Download size={14}/>Ekspor</button>{isA&&<button className="flex items-center gap-2 px-4 py-2 text-xs font-semibold bg-teal-600 text-white rounded-xl shadow-lg shadow-teal-200"><PlusCircle size={14}/>Tambah</button>}</div></div>
            {MOCK_SEARCH_DB.filter(p=>p.source_id!=="pddikti").slice(0,10).map(p=>{const src=API_SOURCES[p.source_id];return<div key={p.id} className="bg-white rounded-xl p-4 shadow-md border border-slate-100 hover:border-teal-200 transition-all" style={{borderLeft:`3px solid ${src?.color}`}}><div className="flex flex-wrap gap-1.5 mb-1"><span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold text-white" style={{backgroundColor:src?.color}}>{src?.icon} {src?.name}</span>{p.grade!=="—"&&<Badge variant={p.grade?.startsWith("Q")?"success":p.grade==="Hibah"?"purple":"info"}>{p.grade}</Badge>}<Badge variant="default">{p.year}</Badge></div><h3 className="text-sm font-bold text-slate-800">{p.title}</h3><p className="text-xs text-slate-500 mt-1">{p.authors.join(", ")||"—"}</p><p className="text-xs text-slate-400 italic">{p.journal}</p>{p.citations>0&&<span className="inline-flex items-center gap-1 text-xs text-amber-600 font-bold mt-1"><TrendingUp size={12}/>{p.citations} sitasi</span>}</div>;})}
          </div>}

          {aM==="sinkronisasi"&&<div className="bg-white rounded-xl p-6 shadow-md border border-slate-100"><h2 className="text-lg font-bold text-slate-800 mb-2 flex items-center gap-2"><RefreshCw size={20} className="text-teal-600"/>Sinkronisasi Data</h2><p className="text-sm text-slate-500 mb-6">Tarik data terbaru dari 6 sumber terbuka.</p>
            <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">{Object.values(API_SOURCES).map((s,i)=>{const ok=i%3!==2;return<div key={s.id} className="rounded-xl border border-slate-200 p-4 flex items-center gap-3"><div className={`w-3 h-3 rounded-full ${ok?"bg-emerald-500":"bg-amber-500"} shadow-lg`}/><div><div className="text-sm font-bold text-slate-700">{s.icon} {s.name}</div><div className={`text-xs ${ok?"text-emerald-600":"text-amber-600"}`}>{ok?"Tersinkron":"Perlu Update"}</div></div></div>;})}</div>
            <button onClick={sync} disabled={syncing} className="px-6 py-3 bg-gradient-to-r from-teal-600 to-cyan-600 text-white font-semibold rounded-xl shadow-xl shadow-teal-200 flex items-center gap-2 text-sm disabled:opacity-60"><RefreshCw size={18} className={syncing?"animate-spin":""}/>{syncing?"Menyinkronkan...":"Sinkronisasi Sekarang"}</button>
          </div>}

          {aM==="kelola-web"&&isA&&<div className="bg-white rounded-xl p-6 shadow-md border border-slate-100"><h2 className="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2"><Edit3 size={20} className="text-teal-600"/>Kelola Konten</h2><div className="space-y-4">{["Hero Section","Profil Jurusan","Informasi Kontak","Konfigurasi API","Banner Pengumuman"].map((s,i)=><div key={i} className="flex items-center justify-between p-4 rounded-xl border border-slate-200 hover:border-teal-200 transition-all"><div className="text-sm font-bold text-slate-700">{s}</div><button className="px-4 py-2 text-xs font-semibold text-teal-700 bg-teal-50 border border-teal-200 rounded-xl flex items-center gap-2"><Edit3 size={13}/>Edit</button></div>)}</div></div>}

          {aM==="analisis"&&isA&&<div className="space-y-6"><div className="bg-white rounded-xl shadow-md border border-slate-100 overflow-hidden"><div className="px-5 py-4 border-b border-slate-100"><h3 className="text-sm font-bold text-slate-700 flex items-center gap-2"><Users size={16} className="text-teal-600"/>Perbandingan Metrik Dosen</h3></div><div className="overflow-x-auto"><table className="w-full text-xs"><thead className="bg-slate-50 text-slate-500 uppercase"><tr><th className="text-left px-5 py-3">Nama</th><th className="text-center px-3 py-3">SINTA</th><th className="text-center px-3 py-3">H-Idx</th><th className="text-center px-3 py-3">Pub</th><th className="text-center px-3 py-3">Scopus</th></tr></thead><tbody className="divide-y divide-slate-100">{RESEARCHERS.map(r=><tr key={r.id} className="hover:bg-teal-50/40"><td className="px-5 py-3"><div className="flex items-center gap-2"><Avatar name={r.name} size={28}/><span className="font-medium text-slate-700 truncate max-w-[200px]">{r.name}</span></div></td><td className="px-3 py-3 text-center font-bold text-teal-700">{r.sinta_score}</td><td className="px-3 py-3 text-center font-bold text-blue-600">{r.h_index}</td><td className="px-3 py-3 text-center font-bold text-slate-700">{r.publications}</td><td className="px-3 py-3 text-center font-bold text-amber-600">{r.scopus}</td></tr>)}</tbody></table></div></div>
            <div className="bg-white rounded-xl p-5 shadow-md border border-slate-100"><h3 className="text-sm font-bold text-slate-700 mb-4"><BarChart3 size={16} className="inline text-teal-600 mr-2"/>Perbandingan</h3><ResponsiveContainer width="100%" height={260}><BarChart data={RESEARCHERS.map(r=>({name:r.name.split(",")[0].split(".").pop().trim(),pub:r.publications,scopus:r.scopus}))}><CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9"/><XAxis dataKey="name" tick={{fontSize:10}} stroke="#94a3b8"/><YAxis tick={{fontSize:11}} stroke="#94a3b8"/><Tooltip contentStyle={{borderRadius:12}}/><Legend verticalAlign="top" height={36}/><Bar dataKey="pub" name="Publikasi" fill="#0d9488" radius={[4,4,0,0]}/><Bar dataKey="scopus" name="Scopus" fill="#f59e0b" radius={[4,4,0,0]}/></BarChart></ResponsiveContainer></div>
          </div>}

          {aM==="kelola-user"&&isA&&<div className="bg-white rounded-xl p-6 shadow-md border border-slate-100"><div className="flex items-center justify-between mb-6"><h2 className="text-lg font-bold text-slate-800 flex items-center gap-2"><Users size={20} className="text-teal-600"/>Kelola Pengguna</h2><button className="flex items-center gap-2 px-4 py-2 text-xs font-semibold bg-teal-600 text-white rounded-xl shadow-lg shadow-teal-200"><PlusCircle size={14}/>Tambah</button></div><div className="space-y-3">{[{name:"Admin Jurusan",email:"admin@polsub.ac.id",role:"Admin"},...RESEARCHERS.map(r=>({name:r.name,email:r.email,role:"Peneliti"}))].map((u,i)=><div key={i} className="flex items-center justify-between p-4 rounded-xl border border-slate-200 hover:border-teal-200"><div className="flex items-center gap-3 min-w-0"><Avatar name={u.name} size={36}/><div><div className="text-sm font-bold text-slate-700 truncate">{u.name}</div><div className="text-xs text-slate-500">{u.email}</div></div></div><div className="flex items-center gap-2"><Badge variant={u.role==="Admin"?"danger":"primary"}>{u.role}</Badge><Badge variant="success">Aktif</Badge></div></div>)}</div></div>}

          {aM==="settings"&&<div className="bg-white rounded-xl p-6 shadow-md border border-slate-100"><h2 className="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2"><Settings size={20} className="text-teal-600"/>Pengaturan</h2><div className="space-y-5 max-w-lg">{[{l:"Nama",v:user.name,t:"text"},{l:"Email",v:user.email,t:"email"},{l:"Sandi",v:"••••••••",t:"password"}].map((f,i)=><div key={i}><label className="block text-xs font-semibold text-slate-700 mb-1.5">{f.l}</label><input type={f.t} defaultValue={f.v} className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 text-sm outline-none"/></div>)}<button className="px-6 py-2.5 bg-teal-600 text-white text-sm font-semibold rounded-xl shadow-lg shadow-teal-200">Simpan</button></div></div>}
        </div>
      </main>
    </div>
  );
}

