function useMultiSourceSearch() {
  const [query, setQuery] = useState("");
  const [category, setCategory] = useState("semua");
  const [enabled, setEnabled] = useState(Object.keys(API_SOURCES).reduce((a,k)=>({...a,[k]:true}),{}));
  const [searching, setSearching] = useState(false);
  const [srcStatus, setSrcStatus] = useState({});
  const [results, setResults] = useState([]);
  const [hasSearched, setHasSearched] = useState(false);

  const toggle = (id) => setEnabled(p=>({...p,[id]:!p[id]}));

  const doSearch = useCallback(async (q) => {
    const term = (q||query).trim().toLowerCase();
    if (!term) return;
    setSearching(true); setHasSearched(true); setResults([]);
    const active = Object.entries(enabled).filter(([,v])=>v).map(([k])=>k);
    const init = {}; active.forEach(s=>{init[s]="loading";}); setSrcStatus(init);

    // TODO: Ganti simulasi ini dengan fetch API asli (lihat kode di atas)
    const filtered = MOCK_SEARCH_DB.filter(item => {
      if (!enabled[item.source_id]) return false;
      if (category==="judul") return item.title.toLowerCase().includes(term);
      if (category==="dosen") return item.authors.some(a=>a.toLowerCase().includes(term));
      if (category==="doi") return item.doi.toLowerCase().includes(term);
      if (category==="institusi") return item.institusi.toLowerCase().includes(term);
      return item.title.toLowerCase().includes(term)||item.authors.some(a=>a.toLowerCase().includes(term))||item.doi.toLowerCase().includes(term)||item.institusi.toLowerCase().includes(term)||item.keywords.some(k=>k.toLowerCase().includes(term))||item.journal.toLowerCase().includes(term)||item.abstract.toLowerCase().includes(term);
    });

    const perSrc = {};
    filtered.forEach(r=>{if(!perSrc[r.source_id])perSrc[r.source_id]=[];perSrc[r.source_id].push(r);});

    let cum = [];
    const delays = [600,500,400,500,400,500];
    for (let i=0;i<active.length;i++) {
      await new Promise(res=>setTimeout(res,delays[i]));
      const sid = active[i];
      if (perSrc[sid]) cum=[...cum,...perSrc[sid]];
      setResults([...cum]);
      setSrcStatus(p=>({...p,[sid]:perSrc[sid]?.length?"done":"empty"}));
    }
    setSearching(false);
  },[query,category,enabled]);

  const clear = ()=>{setQuery("");setResults([]);setHasSearched(false);setSrcStatus({});};
  return { query,setQuery,category,setCategory,enabled,toggle,searching,srcStatus,results,hasSearched,doSearch,clear };
}

